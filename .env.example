# SYNCO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local no repositório.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (Fase 6) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SYNCO

# ── Desenvolvimento ────────────────────────────────────────────────────────────
# Durante a Fase 1-5, auth é simulada via fake-auth.
# Não é necessário configurar Supabase para rodar a aplicação.
